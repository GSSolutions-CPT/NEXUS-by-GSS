<Window x:Class="DCS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DCS"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="520">

    <Grid>
        <TextBlock x:Name="Debugtxt" HorizontalAlignment="Left" Height="224" Margin="29,50,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="209" RenderTransformOrigin="0,0.5" Foreground="Black" Background="Gainsboro" />
        <TextBlock HorizontalAlignment="Left"  TextWrapping="Wrap" Text="Send Door Command" VerticalAlignment="Top" Height="22" Width="223" Margin="29,23,0,0" FontWeight="Bold" FontSize="10" />
        <ComboBox x:Name="cbDoorName"  SelectedIndex="0" HorizontalAlignment="Left" Margin="294,50,0,0" VerticalAlignment="Top" Width="158" />
        <ComboBox x:Name="actionlistCommandList" SelectedIndex="0" HorizontalAlignment="Left" Margin="294,96,0,0" VerticalAlignment="Top" Width="158" />
        <TextBox HorizontalAlignment="Left" Height="23" TextWrapping="Wrap" Text="state" VerticalAlignment="Top" Width="158" x:Name="state" Margin="294,142,0,0" />
        <Button Content="info" HorizontalAlignment="Left" Margin="423,179,0,0" VerticalAlignment="Top" Click="Button_Click_info" Width="29" FontWeight="Bold" BorderBrush="{x:Null}" />
        <Button Content="Send Command" HorizontalAlignment="Left"  VerticalAlignment="Top" Width="132" Height="36" Click="Button_Click_sendaction" Margin="320,340,0,0" FontWeight="Bold" />
        <Button x:Name="serverbutton" Click="Button_Click_server" IsEnabled="False" Content="Change Server" HorizontalAlignment="Left" Margin="29,340,0,0" VerticalAlignment="Top" Width="132" Height="36" />
    </Grid>
</Window>