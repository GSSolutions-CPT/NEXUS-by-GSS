<Window x:Class="DCS.apiServer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DCS"
        mc:Ignorable="d"
        Title="apiServer" Height="220" Width="320">
    <Grid>
        <Label Content="Server IP" HorizontalAlignment="Left" Margin="11,20,0,0" VerticalAlignment="Top" Width="85" Height="23" />
        <TextBox x:Name="IP" HorizontalAlignment="Left" Height="23" Margin="157,20,0,0" TextWrapping="Wrap" Text="127.0.0.1" VerticalAlignment="Top" Width="127" />
        <Label Content="Username" HorizontalAlignment="Left" Margin="11,48,0,0" VerticalAlignment="Top" Width="85" Height="23" />
        <TextBox x:Name="USER" HorizontalAlignment="Left" Height="23" Margin="157,48,0,0" TextWrapping="Wrap" Text="sysdba" VerticalAlignment="Top" Width="127" />
        <Label Content="Password" HorizontalAlignment="Left" Margin="11,77,0,0" VerticalAlignment="Top" Width="85" Height="23" />
        <PasswordBox x:Name="PASS" HorizontalAlignment="Left" Height="23" Margin="157,77,0,0"  VerticalAlignment="Top" Width="127" />
        <Label  Content="Port" HorizontalAlignment="Left" Margin="11,105,0,0" VerticalAlignment="Top" Width="85" Height="23" />
        <TextBox x:Name="PORT" HorizontalAlignment="Left" Height="23" Margin="157,105,0,0" TextWrapping="Wrap" Text="10010" VerticalAlignment="Top" Width="127" />
        <Button Click="Button_Click" Content="Save" HorizontalAlignment="Left" Margin="111,145,0,0" VerticalAlignment="Top" Width="75" />
    </Grid>
</Window>